{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/sync-content.mjs && node scripts/validate-content.mjs",
    "dev": "node scripts/sync-content.mjs && node scripts/validate-content.mjs && next dev",
    "build": "next build",
    "start": "next start",
    "validate": "node scripts/sync-content.mjs && node scripts/validate-content.mjs",
    "lint": "next lint",
    "l:c": "eslint \"./**/*.ts\" \"./**/*.tsx\" \"./**/*.mjs\"",
    "l:f": "eslint \"./**/*.ts\" \"./**/*.tsx\" \"./**/*.mjs\" --fix",
    "p:c": "prettier --config .prettierrc \"./**/*.+(js|json|ts|tsx|mjs)\" --check --ignore-unknown",
    "p:f": "prettier --config .prettierrc \"./**/*.+(js|json|ts|tsx|mjs)\" --write --ignore-unknown"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
